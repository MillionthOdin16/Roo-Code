<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- By default, all files are backed up to cloud -->
        <exclude domain="sharedpref" path="sensitive_preferences.xml" />
        <exclude domain="database" path="roocode_database" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="api_keys.xml" />
    </device-transfer>
</data-extraction-rules>